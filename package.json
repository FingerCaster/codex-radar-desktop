{
  "name": "model-radar",
  "private": true,
  "version": "0.2.0",
  "description": "A compact desktop radar for the current highest-scoring Codex model.",
  "author": "FingerCaster",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings 0",
